# ============================================================
# Bu dosya ne yapar: Cloud ortam değişkenlerini tanımlar.
# Neden var: Signaling, Auth ve TURN servislerinin
#             yapılandırma değerlerini merkezi bir yerden okumasını sağlar.
# Güvenlik notu: .env dosyasını Git'e EKLEMEYİN.
# ============================================================

# Sunucu portu (FATİH: 443 zorunlu)
PORT=443

# JWT gizli anahtar (rastgele, en az 32 karakter)
JWT_SECRET=buraya-guclu-bir-anahtar-yazin

# JWT token ömrü (saniye; 300 = 5 dakika)
JWT_TOKEN_TTL=300

# TLS sertifika yolları
TLS_CERT_PATH=/etc/letsencrypt/live/example.com/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/example.com/privkey.pem

# TURN sunucu bilgileri (istemcilere iletilecek)
TURN_SERVER=turn:example.com:443
TURN_USERNAME=telebot
TURN_PASSWORD=buraya-turn-sifresi-yazin
TURN_REALM=example.com

# Rate limiting (dakika başına istek)
RATE_LIMIT_PER_MINUTE=60

# İzin verilen origin (CORS)
ALLOWED_ORIGIN=*

# Log seviyesi (error | warn | info | debug)
LOG_LEVEL=error
