# ============================================================
# Bu dosya ne yapar: Tüm ortam değişkenlerinin şablonunu içerir.
# Neden var: Yeni geliştiricilerin hangi değişkenleri tanımlaması
#             gerektiğini gösterir. .env dosyası .gitignore'dadır.
# Güvenlik notu: Bu dosyaya GERÇEK anahtar/şifre YAZMAYIN.
#                Bu dosyayı kopyalayıp .env olarak kaydedin,
#                sonra gerçek değerleri .env'ye girin.
# ============================================================

# ==========================================
# CLOUD SUNUCU (signaling + auth + TURN)
# ==========================================

# JWT kimlik doğrulama gizli anahtarı (rastgele, en az 32 karakter)
JWT_SECRET=buraya-guclu-bir-anahtar-yazin

# JWT token ömrü (saniye cinsinden; 300 = 5 dakika)
JWT_TOKEN_TTL=300

# Signaling sunucu portu (FATİH: 443 zorunlu)
SIGNALING_PORT=443

# TLS sertifika yolları (Let's Encrypt veya self-signed)
TLS_CERT_PATH=/etc/letsencrypt/live/example.com/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/example.com/privkey.pem

# ==========================================
# TURN SUNUCU (coturn)
# ==========================================

# TURN sunucu adresi (dış IP veya domain)
TURN_SERVER=turn:example.com:443

# TURN kullanıcı adı ve şifresi
TURN_USERNAME=telebot
TURN_PASSWORD=buraya-turn-sifresi-yazin

# TURN realm (genellikle domain adı)
TURN_REALM=example.com

# ==========================================
# RASPBERRY PI
# ==========================================

# Signaling sunucu WebSocket URL'si
SIGNALING_URL=wss://example.com:443/ws

# Kamera cihazı (genellikle /dev/video0)
CAMERA_DEVICE=/dev/video0

# Video çözünürlük ve FPS
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS=30

# Video bitrate (bps cinsinden; 1500000 = 1.5 Mbps)
VIDEO_BITRATE=1500000

# MCU serial port (genellikle /dev/ttyUSB0 veya /dev/ttyACM0)
MCU_SERIAL_PORT=/dev/ttyUSB0
MCU_SERIAL_BAUD=115200

# LED GPIO pin numarası (BCM numaralandırma)
LED_GPIO_PIN=17

# Servo kontrolü (RPi tarafında — ESP32'de değil)
# Doğrudan GPIO PWM kullanılıyorsa:
SERVO_PAN_PIN=12
SERVO_TILT_PIN=13
# PCA9685 I2C sürücü kullanılıyorsa:
# SERVO_USE_PCA9685=true
# PCA9685_I2C_ADDRESS=0x40
# SERVO_PAN_CHANNEL=0
# SERVO_TILT_CHANNEL=1

# Heartbeat gönderim aralığı (ms; MCU watchdog 500ms olduğu için <500 olmalı)
HEARTBEAT_INTERVAL_MS=200

# ==========================================
# MCU (ESP32/Arduino) - NOT: MCU .env kullanmaz,
# bu değerler firmware'de config.h'ye yazılır.
# Referans olarak burada belgelenir.
# ==========================================

# Watchdog timeout (ms)
# MCU_WATCHDOG_TIMEOUT_MS=500

# Engel algılama mesafesi (cm)
# MCU_OBSTACLE_DISTANCE_CM=30

# Maksimum PWM değeri (%60 cap → 153/255)
# MCU_MAX_PWM=153

# Smooth ramp süresi (ms; 0→max)
# MCU_RAMP_DURATION_MS=1000
