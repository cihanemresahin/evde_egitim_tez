# ============================================================
# Bu dosya ne yapar: Raspberry Pi ortam değişkenlerini tanımlar.
# Neden var: RPi servislerinin (kamera, WebRTC, serial köprü, LED)
#             yapılandırma değerlerini merkezi bir yerden okumasını sağlar.
# Güvenlik notu: .env dosyasını Git'e EKLEMEYİN.
#                Bu şablonu .env olarak kopyalayıp doldurun.
# ============================================================

# Signaling sunucu WebSocket URL'si
SIGNALING_URL=wss://example.com:443/ws

# JWT Token (oturum başına auth sunucudan alınır)
# Otomatik alınacak, burada sadece test için manuel girilebilir
# AUTH_TOKEN=

# Kamera ayarları
CAMERA_DEVICE=/dev/video0
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS=30
VIDEO_BITRATE=1500000

# TURN sunucu bilgileri
TURN_SERVER=turn:example.com:443
TURN_USERNAME=telebot
TURN_PASSWORD=buraya-turn-sifresi-yazin

# MCU Serial bağlantı
MCU_SERIAL_PORT=/dev/ttyUSB0
MCU_SERIAL_BAUD=115200

# LED GPIO (BCM numaralandırma)
LED_GPIO_PIN=17

# Servo kontrolü (pan/tilt — RPi tarafında kontrol edilir)
SERVO_PAN_PIN=12
SERVO_TILT_PIN=13
# PCA9685 I2C kullanılıyorsa:
# SERVO_USE_PCA9685=true
# PCA9685_I2C_ADDRESS=0x40
# SERVO_PAN_CHANNEL=0
# SERVO_TILT_CHANNEL=1

# Heartbeat aralığı (ms) - MCU watchdog 500ms, bu değer <500 olmalı
HEARTBEAT_INTERVAL_MS=200
